*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.*
!.env.example

# Coverage and caches
coverage/
.vite/
.cache/

# OS/editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
